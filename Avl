class Node:
    def __init__(self, key):
        self.key = key
        self.left = None
        self.right = None
        self.height = 1


class AVLTree:

    def get_height(self, node):
        if not node:
            return 0
        return node.height

    def get_balance(self, node):
        if not node:
            return 0
        return self.get_height(node.left) - self.get_height(node.right)

    def right_rotate(self, y):
        x = y.left
        T2 = x.right

        x.right = y
        y.left = T2

        y.height = 1 + max(self.get_height(y.left), self.get_height(y.right))
        x.height = 1 + max(self.get_height(x.left), self.get_height(x.right))

        return x

    def left_rotate(self, x):
        y = x.right
        T2 = y.left

        y.left = x
        x.right = T2

        x.height = 1 + max(self.get_height(x.left), self.get_height(x.right))
        y.height = 1 + max(self.get_height(y.left), self.get_height(y.right))

        return y

    def insert(self, root, key):
        if not root:
            return Node(key), "No rotation"

        if key < root.key:
            root.left, rotation = self.insert(root.left, key)
        else:
            root.right, rotation = self.insert(root.right, key)

        root.height = 1 + max(self.get_height(root.left), self.get_height(root.right))

        balance = self.get_balance(root)

        rotation = "No rotation"

        # LL
        if balance > 1 and key < root.left.key:
            rotation = "LL Rotation"
            root = self.right_rotate(root)

        # RR
        elif balance < -1 and key > root.right.key:
            rotation = "RR Rotation"
            root = self.left_rotate(root)

        # LR
        elif balance > 1 and key > root.left.key:
            rotation = "LR Rotation"
            root.left = self.left_rotate(root.left)
            root = self.right_rotate(root)

        # RL
        elif balance < -1 and key < root.right.key:
            rotation = "RL Rotation"
            root.right = self.right_rotate(root.right)
            root = self.left_rotate(root)

        return root, rotation


    def print_tree(self, node, level=0, prefix="Root: "):
        if node:
            print(" " * (level * 4) + prefix + str(node.key))
            self.print_tree(node.left, level + 1, "L--- ")
            self.print_tree(node.right, level + 1, "R--- ")


# MAIN PROGRAM

keys = [44, 17, 32, 78, 50, 88, 48, 62, 54]

tree = AVLTree()
root = None

log = []

for key in keys:

    print("\nInserting:", key)

    root, rotation = tree.insert(root, key)

    print("Rotation:", rotation)

    print("Tree Structure:")
    tree.print_tree(root)

    log.append(f"Inserting: {key}")
    log.append(f"Rotation: {rotation}")
    log.append("Tree Structure:")
    
    # Capture tree structure in text
    def capture_tree(node, level=0, prefix="Root: "):
        if node:
            log.append(" " * (level * 4) + prefix + str(node.key))
            capture_tree(node.left, level + 1, "L--- ")
            capture_tree(node.right, level + 1, "R--- ")

    capture_tree(root)
    log.append("")


# SAVE FILE

with open("avl_insertion_results.txt", "w") as f:
    for line in log:
        f.write(line + "\n")

print("\nResults saved to avl_insertion_results.txt")
